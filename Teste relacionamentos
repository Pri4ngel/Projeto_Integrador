-- ====================================================
-- RELATÓRIOS E JOINS
-- ====================================================

--- Movimentação de usuário e insumo ---
SELECT
    m.id_movimentacao,
    i.nome_insumo AS insumo,       -- Atualizado: nome -> nome_insumo
    u.nome AS usuario,
    s.nome_setor,
    m.tipo_movimentacao,
    m.quantidade,
    m.data_operacao AS data_hora   -- Atualizado: data_movimentacao -> data_operacao
FROM movimentacoes m
INNER JOIN insumos i ON m.id_insumo = i.id_insumo
INNER JOIN usuarios u ON m.id_usuario = u.id_usuario
INNER JOIN setores s ON m.id_setor = s.id_setor;


--- Lotes e insumos utilizados na produção ---
SELECT
    lp.codigo_lote,
    i.nome_insumo,                 -- Atualizado: nome -> nome_insumo
    li.quantidade_utilizada
FROM lote_insumos li
INNER JOIN lotes_producao lp 
    ON li.id_lote = lp.id_lote
INNER JOIN insumos i 
    ON li.id_insumo = i.id_insumo;


--- Alertas de estoque ativo ---
SELECT
    a.id_alerta,
    i.nome_insumo,                 -- Atualizado: nome -> nome_insumo
    a.mensagem,
    a.status_alerta
FROM alertas_estoque a
INNER JOIN insumos i 
    ON a.id_insumo = i.id_insumo;


